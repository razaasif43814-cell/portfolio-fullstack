# ═══════════════════════════════════════════
#  Environment Variables — Copy to .env
#  NEVER commit .env to GitHub!
# ═══════════════════════════════════════════

# Flask
SECRET_KEY=your-strong-secret-key-here-change-this
FLASK_DEBUG=False

# JWT
JWT_SECRET=your-strong-jwt-secret-here-change-this
JWT_EXPIRY_HOURS=24

# MongoDB — Local
# MONGO_URI=mongodb://localhost:27017/portfolio

# MongoDB — Atlas (Production on Render)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority
MONGO_DB_NAME=portfolio

# Gmail SMTP (App Password — not your Gmail password)
# Setup: Google Account > Security > 2FA > App Passwords
GMAIL_USER=razaasif43814@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx
TO_EMAIL=razaasif43814@gmail.com

# Server (Render sets PORT automatically)
HOST=0.0.0.0
PORT=5000
